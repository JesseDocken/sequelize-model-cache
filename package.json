{
  "name": "sequelize-model-cache",
  "description": "A model cache layer that integrates with Sequelize with support for Redis.",
  "version": "0.5.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JesseDocken/sequelize-model-cache.git"
  },
  "bugs": {
    "url": "https://github.com/JesseDocken/sequelize-model-cache/issues"
  },
  "homepage": "https://github.com/JesseDocken/sequelize-model-cache",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": null
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/",
    "!dist/.tsbuildinfo",
    "index.ts",
    "lib/",
    "sequelize-cached-model.d.ts",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:unit": "vitest run unit/",
    "test:integration": "vitest run test/",
    "test:integration:docker": "docker compose up -d --wait && vitest run test/; s=$?; docker compose down; exit $s",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:docker": "docker compose up -d --wait && vitest run --coverage; s=$?; docker compose down; exit $s",
    "prepublishOnly": "npm run clean && npm run build && npm run test:unit"
  },
  "license": "MIT",
  "dependencies": {
    "lodash": "^4.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@opentelemetry/api": "^1.9.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/config": "^3.3.5",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "debug": "^4.4.3",
    "esdoc": "^1.1.0",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "^61.7.1",
    "eslint-plugin-n": "^17.24.0",
    "globals": "^17.4.0",
    "ioredis": "^5.10.1",
    "jiti": "^2.6.1",
    "mariadb": "^3.5.2",
    "mocha": "^11.7.5",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "sequelize": "^6.37.8",
    "sqlite3": "^6.0.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2",
    "winston": "^3.19.0"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.0.0",
    "debug": "^4.0.0",
    "ioredis": "^5.0.0",
    "pino": "^8.0.0 || ^9.0.0 || ^10.0.0",
    "prom-client": "^15.0.0",
    "sequelize": "^6.0.0",
    "winston": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    },
    "debug": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "pino": {
      "optional": true
    },
    "prom-client": {
      "optional": true
    },
    "sequelize": {
      "optional": false
    },
    "winston": {
      "optional": true
    }
  },
  "keywords": [
    "nodejs",
    "sequelize",
    "cache",
    "db",
    "redis"
  ]
}
